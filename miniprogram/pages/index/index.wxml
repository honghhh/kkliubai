<view class="page">
  <view class="topbar">
    <text class="title">{{activeTab === 0 ? '作品欣赏' : '个人简介'}}</text>
  </view>

  <view wx:if="{{activeTab === 0}}">
    <scroll-view class="category-bar" scroll-x enable-flex show-scrollbar="false">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-item {{activeCategoryId === item.id ? 'active' : ''}}"
        bindtap="onTapCategory"
        data-id="{{item.id}}"
      >
        {{item.name}}
      </view>
    </scroll-view>

    <scroll-view class="content" scroll-y bindscrolltolower="onScrollToLower" lower-threshold="120">
      <view wx:if="{{activeCategoryId === 6}}" class="aesthetic-switch-row">
        <text class="aesthetic-switch-label">{{aestheticZoomEnabled ? '图片放大已开启' : '图片放大已关闭'}}</text>
        <switch checked="{{aestheticZoomEnabled}}" bindchange="onToggleAestheticZoom" color="#65d2c0" />
      </view>

      <view wx:if="{{activeCategoryId !== 7}}" class="gallery-grid">
        <view wx:for="{{displayImages}}" wx:key="src" class="card">
          <image
            class="photo"
            src="{{item.src}}"
            mode="aspectFill"
            lazy-load="true"
            bindtap="onTapImage"
            data-src="{{item.src}}"
          />
          <text class="corner-tag">{{item.tag}}</text>
        </view>
      </view>

      <view wx:if="{{activeCategoryId === 7}}" class="video-panel">
        <view class="video-switch-row">
          <text class="video-switch-label">{{videoVisible ? '显示' : '隐藏'}}</text>
          <switch checked="{{videoVisible}}" bindchange="onToggleVideoVisible" color="#65d2c0" />
        </view>

        <view wx:if="{{videoVisible}}" class="video-list">
          <view wx:for="{{displayVideos}}" wx:key="id" class="video-item">
            <text class="video-title">{{item.title}}</text>
            <video
              id="video-{{item.id}}"
              class="video-player"
              data-id="{{item.id}}"
              src="{{item.src}}"
              poster="{{item.poster}}"
              controls
              show-fullscreen-btn
              bindfullscreenchange="onVideoFullscreenChange"
              bindended="onVideoEnded"
            ></video>
            <view class="video-actions">
              <button
                class="video-fullscreen-btn"
                size="mini"
                data-id="{{item.id}}"
                bindtap="onTapVideoFullscreen"
                disabled="{{fullscreenVideoId === item.id}}"
              >
                {{fullscreenVideoId === item.id ? '全屏播放中' : '全屏播放'}}
              </button>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <scroll-view wx:if="{{activeTab === 1}}" class="profile-content" scroll-y>
    <image class="profile-img" src="/images/个人简介.jpg" mode="widthFix" bindtap="onTapProfileImage" />
  </scroll-view>

  <view class="tabbar">
    <view class="tabbar-item {{activeTab === 0 ? 'tabbar-active' : ''}}" bindtap="onTapTab" data-tab="0">
      <view class="tabbar-icon">
        <view class="icon-layers">
          <view class="icon-layer"></view>
          <view class="icon-layer"></view>
          <view class="icon-layer"></view>
        </view>
      </view>
      <text class="tabbar-label">作品欣赏</text>
    </view>
    <view class="tabbar-item {{activeTab === 1 ? 'tabbar-active' : ''}}" bindtap="onTapTab" data-tab="1">
      <view class="tabbar-icon">
        <view class="icon-profile">
          <view class="icon-profile-head"></view>
          <view class="icon-profile-body"></view>
        </view>
      </view>
      <text class="tabbar-label">个人简介</text>
    </view>
  </view>
</view>
